# =============================================================================
# FARADAY CONTRACTS — contracts/.env
# Used by: forge script, forge test, cast
# Copy to contracts/.env and fill in values.
# =============================================================================

# -----------------------------------------------------------------------------
# ARC Testnet RPC
# Get your personal URL: arc-canteen rpc-url
# -----------------------------------------------------------------------------
ARC_RPC_URL=https://rpc.testnet.arc-node.thecanteenapp.com/v1/<your-key>

# -----------------------------------------------------------------------------
# Deployer wallet
# Recommendation: use cast wallet import instead of raw private key
#   cast wallet import deployer --interactive
#   Then deploy with: --account deployer
# Only use raw key for quick local testing.
# -----------------------------------------------------------------------------
PRIVATE_KEY=0x<your-deployer-private-key>
DEPLOYER_ADDRESS=0x<your-deployer-wallet-address>

# -----------------------------------------------------------------------------
# Agent wallet — the Circle developer-controlled wallet address
# This is the address that FaradayVault grants permission to call executeProtection()
# Get this after creating a Circle developer wallet (see agent/.env.example)
# -----------------------------------------------------------------------------
AGENT_WALLET_ADDRESS=0x<circle-developer-wallet-address>

# -----------------------------------------------------------------------------
# ARC Testnet contract addresses (do not change)
# -----------------------------------------------------------------------------
USDC_ADDRESS=0x3600000000000000000000000000000000000000
USYC_ADDRESS=0xe9185F0c5F296Ed1797AaE4238D26CCaBEadb86C
USYC_TELLER_ADDRESS=0x9fdF14c5B14173D74C08Af27AebFf39240dC105A
GATEWAY_WALLET_ADDRESS=0x0077777d7EBA4688BDeF3E311b846F25870A19B9

# -----------------------------------------------------------------------------
# Block explorer API key (optional — only needed for contract verification)
# -----------------------------------------------------------------------------
ARCSCANNER_API_KEY=
