# =============================================================================
# FARADAY MCP SERVER — mcp/.env
# Used by: the MCP server (src/index.ts) — exposes Faraday tools to AI agents
# Copy to mcp/.env and fill in values.
# =============================================================================

# ARC Testnet RPC
ARC_RPC_URL=https://rpc.testnet.arc-node.thecanteenapp.com/v1/<your-key>

# Faraday contracts on ARC — filled AFTER deploying with forge
POSITION_REGISTRY_ADDRESS=0x<deployed-registry-address>
FARADAY_VAULT_ADDRESS=0x<deployed-vault-address>
