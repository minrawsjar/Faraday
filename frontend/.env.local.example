# =============================================================================
# FARADAY FRONTEND — frontend/.env.local
# Used by: Next.js app (NEXT_PUBLIC_ vars are exposed to the browser)
# Copy to frontend/.env.local and fill in values.
# Never put private keys or Circle API keys in NEXT_PUBLIC_ variables.
# =============================================================================

# ARC Testnet RPC — visible in browser, use a restricted or public key
# Get yours: arc-canteen rpc-url
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc-node.thecanteenapp.com/v1/<your-key>

# Other chain RPCs (for reading Aave/Venus positions in the UI)
NEXT_PUBLIC_ETH_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/<your-key>
NEXT_PUBLIC_ARB_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/<your-key>
NEXT_PUBLIC_BNB_RPC_URL=https://bsc-testnet.publicnode.com

# Faraday contracts — fill AFTER deploying with forge
NEXT_PUBLIC_VAULT_ADDRESS=0x<deployed-vault-address>
NEXT_PUBLIC_REGISTRY_ADDRESS=0x<deployed-registry-address>

# ARC Testnet token addresses (do not change)
NEXT_PUBLIC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
NEXT_PUBLIC_USYC_ADDRESS=0xe9185F0c5F296Ed1797AaE4238D26CCaBEadb86C
