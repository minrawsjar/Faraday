# =============================================================================
# FARADAY AGENT — agent/.env
# Used by: the autonomous monitoring + execution loop (src/index.ts)
# Copy to agent/.env and fill in values.
# =============================================================================

# -----------------------------------------------------------------------------
# ARC Testnet RPC
# -----------------------------------------------------------------------------
ARC_RPC_URL=https://rpc.testnet.arc-node.thecanteenapp.com/v1/<your-key>

# -----------------------------------------------------------------------------
# Other chain RPCs — agent reads health factors from these chains
# -----------------------------------------------------------------------------
ETH_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/<your-key>
ARB_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/<your-key>
BNB_RPC_URL=https://bsc-testnet.publicnode.com

# -----------------------------------------------------------------------------
# Circle developer-controlled wallet
# Create at: https://console.circle.com → Wallets → Developer Controlled
# The wallet address becomes AGENT_WALLET_ADDRESS in your contracts
# The wallet's private key signs executeProtection() + logIntervention() txs
# IMPORTANT: this wallet should ONLY have permission to call those two functions
# -----------------------------------------------------------------------------
CIRCLE_API_KEY=<your-circle-api-key>
CIRCLE_WALLET_ID=<your-circle-wallet-id>
AGENT_PRIVATE_KEY=0x<circle-wallet-private-key>

# -----------------------------------------------------------------------------
# Claude API — powers the AI decision layer (brain/decide.ts)
# Get at: https://console.anthropic.com
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-<your-key>

# -----------------------------------------------------------------------------
# Faraday contracts on ARC — filled AFTER deploying with forge
# -----------------------------------------------------------------------------
FARADAY_VAULT_ADDRESS=0x<deployed-vault-address>
POSITION_REGISTRY_ADDRESS=0x<deployed-registry-address>

# -----------------------------------------------------------------------------
# Agent tuning (optional — defaults shown)
# -----------------------------------------------------------------------------
POLL_INTERVAL_MS=30000
